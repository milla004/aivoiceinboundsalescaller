# =============================================================================
# AI Inbound Voice Sales Agent — Environment Variables (TEMPLATE)
# Copy to .env.local (dashboard) and .env (agent). Never commit the real file.
# =============================================================================

# ---- Supabase (database + storage) -----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never exposed to browser

# ---- Gemini Live (STT + LLM + TTS in one realtime model) -------------------
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-live-001

# ---- LiveKit (telephony <-> realtime orchestration) ------------------------
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ---- Telnyx (US inbound SIP trunk + numbers) -------------------------------
TELNYX_API_KEY=your-telnyx-api-key

# ---- Payment (Authorize.net SANDBOX — no real charges until bank is ready) --
PAYMENT_MODE=sandbox                       # sandbox | live  (keep sandbox for now)
AUTHORIZENET_API_LOGIN_ID=your-sandbox-login
AUTHORIZENET_TRANSACTION_KEY=your-sandbox-key

# ---- Dashboard <-> Agent shared secret (internal API auth) -----------------
INTERNAL_API_SECRET=generate-a-long-random-string
